# apps/api
PORT=3001
WEB_ORIGIN=http://localhost:3000
SUPABASE_URL=https://example.supabase.co
SUPABASE_SECRET_KEY=sb_secret_example
# OpenRouter API 키 — AI 분류는 preset `@preset/my-bookmark` 단일 호출로 동작한다.
# 모델 선택/폴백/파라미터는 openrouter.ai의 preset 설정이 담당한다.
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_MANAGEMENT_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:
# reverse proxy(Caddy 등) 뒤에서는 hop 수를 지정 (예: 1). 비우면 미적용
TRUST_PROXY=1
# 서버 전용 Discord Webhook. web에 노출하지 않는다.
DISCORD_ALERT_WEBHOOK_URL=
ALERT_ENV=home-production

# apps/web
VITE_SUPABASE_URL=https://example.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_example
VITE_API_URL=http://localhost:3001
VITE_VAPID_PUBLIC_KEY=
