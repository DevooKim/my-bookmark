{
  "name": "@my-bookmark/web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build:sw": "esbuild src/sw/sw.ts --bundle --format=iife --target=es2022 --outfile=public/sw.js",
    "dev": "esbuild src/sw/sw.ts --bundle --format=iife --target=es2022 --outfile=public/sw.js --watch=forever & vite dev --port 3000",
    "generate-routes": "tsr generate",
    "typecheck": "bun run generate-routes && tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "build": "bun run build:sw && bun run generate-routes && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@my-bookmark/shared": "workspace:*",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-virtual": "^3.14.5",
    "@tanstack/router-plugin": "^1.132.0",
    "heic-decode": "^2.1.0",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/heic-decode": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "jsdom": "^28.1.0",
    "typescript": "7.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
