{
  "name": "my-bookmark",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' --parallel --if-present dev",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "lint": "bun run --workspaces --if-present lint",
    "test": "bun run --workspaces --if-present test",
    "build": "bun run --workspaces --if-present build"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "supabase": "^2.109.0",
    "typescript": "latest"
  },
  "trustedDependencies": [
    "esbuild",
    "lightningcss"
  ]
}
